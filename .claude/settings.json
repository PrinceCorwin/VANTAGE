{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git pull:*)",
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(cat:*)",
      "Bash(dotnet add package:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet clean:*)",
      "Bash(dotnet list:*)",
      "Bash(dotnet package:*)",
      "Bash(dotnet publish:*)",
      "Bash(dotnet remove:*)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet sln:*)",
      "Bash(gh auth:*)",
      "Bash(gh config:*)",
      "Bash(gh release create:*)",
      "Bash(gh repo:*)",
      "Bash(powershell:*)",
      "PowerShell(New-Item *)",
      "PowerShell(git *)",
      "PowerShell(dotnet build *)",
      "PowerShell(python *)",
      "PowerShell(Get-Content *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Get-Item *)",
      "PowerShell(Get-Command *)",
      "PowerShell(Test-Path *)",
      "PowerShell(Join-Path *)",
      "PowerShell(Select-Object *)",
      "PowerShell(Measure-Object *)",
      "PowerShell(ConvertFrom-Json *)",
      "PowerShell(ConvertTo-Json *)",
      "PowerShell(Copy-Item *)",
      "Bash(cp:*)",
      "Bash(curl:*)",
      "Bash(find:*)",
      "Bash(findstr:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(PYTHONUTF8=1 python:*)",
      "Bash(PYTHONUTF8=1 python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pip install:*)",
      "Bash(sort:*)",
      "Bash(sqlite3:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(stat:*)",
      "Bash(echo:*)",
      "Bash(diff:*)",
      "Bash(cut:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(which:*)",
      "Bash(where:*)",
      "Bash(tasklist:*)",
      "Bash(taskkill:*)",
      "Bash(tree:*)",
      "Bash(unzip:*)",
      "Bash(wc:*)",
      "Bash(zip:*)",
      "Skill(finisher)",
      "Skill(speedup)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:help.syncfusion.com)",
      "WebFetch(domain:www.syncfusion.com)",
      "WebFetch(domain:support.syncfusion.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(cd *)",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-cd-vantage.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/normalize-crlf.py\""
          }
        ]
      }
    ]
  }
}
