<syncfusion:ChromelessWindow x:Class="VANTAGE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:views="clr-namespace:VANTAGE.Views"
        mc:Ignorable="d"
        Title="VANTAGE: MILESTONE"
        ShowTitle="False"                   
        TitleBarHeight="0"
        Height="1080"
        Width="1920"
        WindowState="Maximized"
        Background="{DynamicResource BackgroundColor}"
        Icon="pack://application:,,,/images/AppIcon.ico"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <syncfusion:ChromelessWindow.Resources>
        <!-- Nav button style with themed hover colors -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ToolbarForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="navBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="navBorder" Property="Background" Value="{DynamicResource ToolbarHoverBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ToolbarHoverForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </syncfusion:ChromelessWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <!-- TOOLBAR -->
        <Border Grid.Row="0"
                Background="{DynamicResource DarkestBackgroundColor}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid Height="40">
                <Grid.ColumnDefinitions>
                    <!-- Navigation -->
                    <ColumnDefinition Width="*"/>
                    <!-- APP TOOLS -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Window controls -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

               

                <!-- COLUMN 1: /APP MENU ITEMS -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Width="35" 
                           Margin="10,0,20,0"
                           Source="pack://application:,,,/images/MilestoneLogoPngTransparentBG.png" 
                           Stretch="Uniform" />

                    <syncfusion:DropDownButtonAdv x:Name="btnFile"
                                Label="File"
                                Padding="0"
                                Margin="5,0"
                                Background="Transparent"
                                Foreground="{DynamicResource ToolbarForeground}"
                                BorderThickness="0"
                                IconTemplate="{x:Null}"
                                SmallIcon="{x:Null}"
                                LargeIcon="{x:Null}"
                                FontSize="12"
                                SizeMode="Normal"
                                ToolTip="File actions">
                        <syncfusion:DropDownMenuGroup
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource BorderColor}">
                            <!-- Activities -->
                            <syncfusion:DropDownMenuItem Header="Import Activities (Replace)" Click="MenuExcelImportReplace_Click" ToolTip="Auto-detects Legacy or Milestone format, replaces all existing activities"/>
                            <syncfusion:DropDownMenuItem Header="Import Activities (Combine)" Click="MenuExcelImportCombine_Click" ToolTip="Auto-detects Legacy or Milestone format, adds to existing activities"/>
                            <syncfusion:DropDownMenuItem Header="Export Activities" Click="ExcelExportActivities_Click"/>
                            <syncfusion:DropDownMenuItem Header="Export Activities Template" Click="ExcelExportTemplate_Click"/>
                            <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                            <syncfusion:DropDownMenuItem Header="Import from AI Takeoff" Click="BtnCreate_Click" ToolTip="Import activities from an AI Takeoff Excel file or batch"/>
                            <syncfusion:DropDownMenuItem Header="Clear Local Activities" Click="MenuClearLocalActivities_Click"/>
                            <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                            <!-- P6 Files -->
                            <syncfusion:DropDownMenuItem Header="Import From P6 File" Click="ImportP6File_Click"/>
                            <syncfusion:DropDownMenuItem Header="Export To P6 File" Click="ExportP6File_Click"/>
                            <syncfusion:DropDownMenuItem Header="Clear Local Schedule" Click="MenuClearLocalSchedule_Click"/>
                            <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                            <!-- Other -->
                            <syncfusion:DropDownMenuItem Header="Export Logs" Click="MenuExportLogs_Click"/>
                            <syncfusion:DropDownMenuItem Header="Manage My Snapshots" Click="MenuManageSnapshots_Click"/>
                            <!-- Legacy Export section -->
                            <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                            <syncfusion:DropDownMenuItem Header="Legacy Export Activities" Click="MenuLegacyExportActivities_Click" ToolTip="Export to OldVantage format (percentages as 0-1 decimals)"/>
                            <syncfusion:DropDownMenuItem Header="Legacy Export Template" Click="MenuLegacyExportTemplate_Click" ToolTip="Export empty template with OldVantage column headers"/>
                        </syncfusion:DropDownMenuGroup>
                    </syncfusion:DropDownButtonAdv>

                    <syncfusion:DropDownButtonAdv x:Name="btnTools"
                              Label="Tools"
                              Padding="0"
                              Margin="5,0"
                              Background="Transparent"
                              Foreground="{DynamicResource ToolbarForeground}"
                              BorderThickness="0"
                              IconTemplate="{x:Null}"
                              SmallIcon="{x:Null}"
                              LargeIcon="{x:Null}"
                              FontSize="12"
                              SizeMode="Normal"
                              ToolTip="Utilities and maintenance options">
                        <syncfusion:DropDownMenuGroup x:Name="ToolsMenuGroup"
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource BorderColor}">
                            <syncfusion:DropDownMenuItem Header="Help Sidebar     (F1)" Click="MenuHelpSidebar_Click" ToolTip="Open the help sidebar"/>
                            <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                            <syncfusion:DropDownMenuItem Header="Prorate MHs" Click="MenuProrateMHs_Click"/>
                            <syncfusion:DropDownMenuItem Header="Schedule Change Log" Click="MenuScheduleChangeLog_Click" ToolTip="View and apply changes made in the Schedule detail grid"/>
                            <syncfusion:DropDownMenuItem Header="Schedule UDF Mapping..." Click="MenuScheduleUDFMapping_Click" ToolTip="Configure custom P6 UDF column mappings"/>
                            <syncfusion:DropDownMenuItem Header="ROC Manager" Click="MenuROCManager_Click" ToolTip="Create, view, modify, or delete ROC rate sets"/>
                            <syncfusion:DropDownMenuItem Header="ActNO Split Ownership Check" Click="MenuOwnershipCheck_Click" ToolTip="Check for split ActNO ownership across users in a project"/>
                            <syncfusion:DropDownMenuItem Header="VP vs Vtg Report" Click="MenuVPvsVtgReport_Click" ToolTip="Augment a JC Labor Productivity report with Vantage Earned and Budget MHs, flagging differences over 1%"/>
                            <!-- Plugin menu items are added dynamically below this point -->
                        </syncfusion:DropDownMenuGroup>
                    </syncfusion:DropDownButtonAdv>

                    <syncfusion:DropDownButtonAdv x:Name="btnAdmin"
                              Label="Admin"
                              Padding="0"
                              Margin="5,0"
                          Background="Transparent"
                          Foreground="{DynamicResource ToolbarForeground}"
                              BorderThickness="0"
                              IconTemplate="{x:Null}"
                              SmallIcon="{x:Null}"
                              LargeIcon="{x:Null}"
                              FontSize="12"
                              SizeMode="Normal">
                        <syncfusion:DropDownMenuGroup
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource BorderColor}">
                            <syncfusion:DropDownMenuItem Header="Edit Users" Click="MenuEditUsers_Click"/>
                            <syncfusion:DropDownMenuItem Header="Edit Projects" Click="MenuEditProjects_Click"/>
                            <syncfusion:DropDownMenuItem Header="Manage Snapshots" Click="MenuEditSnapshots_Click"/>
                            <syncfusion:DropDownMenuItem Header="Manage Progress Log" Click="MenuManageProgressLog_Click"/>
                            <syncfusion:DropDownMenuItem Header="Manage S3 Drawings" Click="MenuManageS3Drawings_Click" ToolTip="View and delete orphaned drawings in S3"/>
                            <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                            <syncfusion:DropDownMenuItem Header="Project Rates" Click="MenuProjectRates_Click" ToolTip="Manage per-project unit rate overrides"/>
                            <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                            <syncfusion:DropDownMenuItem Header="Deleted Records UI" Click="DeletedRecordsUi_Click"/>
                        </syncfusion:DropDownMenuGroup>
                    </syncfusion:DropDownButtonAdv>

                </StackPanel>
                <!-- COLUMN 2: NAVIGATION BUTTONS -->

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <Grid Margin="10,0">
                        <Button x:Name="btnProgress"
                                Content="PROGRESS"
                                Padding="15,0,15,6"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnProgress_Click"
                                ToolTip="Track activity completion and earned values"/>
                        <Border x:Name="borderProgress"
                                Height="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                    </Grid>
                    <Grid Margin="10,0">
                        <Button x:Name="btnSchedule"
                                Content="SCHEDULE"
                                Padding="15,0,15,6"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnSchedule_Click"
                                ToolTip="View and edit P6 schedule data"/>
                        <Border x:Name="borderSchedule"
                                Height="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                    </Grid>
                    <Grid Margin="10,0">
                        <Button x:Name="btnPbook"
                                Content="PROG BOOKS"
                                Padding="15,0,15,6"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnPbook_Click"
                                ToolTip="Generate progress books"/>
                        <Border x:Name="ProgBookBorder"
                                Height="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                    </Grid>
                    <Grid Margin="10,0">
                        <Button x:Name="btnWorkPackage"
                                Content="WORK PKGS"
                                Padding="15,0,15,6"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnWorkPackage_Click"
                                ToolTip="Manage work packages"/>
                        <Border x:Name="WorkPackageBorder"
                                Height="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                    </Grid>
                    <Grid Margin="10,0">
                        <Button x:Name="btnAnalysis"
                                Content="ANALYSIS"
                                Padding="15,0,15,6"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnAnalysis_Click"
                                ToolTip="View project analytics and dashboards"/>
                        <Border x:Name="AnalysisBorder"
                                Height="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                    </Grid>
                    <Grid Margin="10,0">
                        <Button x:Name="btnTakeoff"
                                Content="TAKEOFFS"
                                Padding="15,0,15,6"
                                Style="{StaticResource NavButtonStyle}"
                                Click="BtnTakeoff_Click"
                                ToolTip="AI-powered piping takeoff extraction"/>
                        <Border x:Name="TakeoffBorder"
                                Height="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="Transparent"/>
                    </Grid>
                </StackPanel>
                
                <!-- COLUMN 3: WINDOW CONTROLS (RIGHT) -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Settings Button + Popup -->
                    <Button x:Name="btnSettings"
                            Content="⋮"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Padding="8,0"
                            Margin="5,0,10,0"
                            FontSize="16"
                            FontWeight="Bold"
                            ToolTip="Settings"
                            Click="BtnSettings_Click"/>

                    <Popup x:Name="popupSettings"
                           PlacementTarget="{Binding ElementName=btnSettings}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Border Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="0">
                            <StackPanel>
                                <Button Content="Help Sidebar   (F1)"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuHelpSidebar_Click"
                                        Cursor="Hand"/>
                                <Button Content="Feedback Board"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuFeedbackBoard_Click"
                                        Cursor="Hand"
                                        ToolTip="Submit ideas or report bugs"/>
                                <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                                <Button Content="Import Settings"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuImportSettings_Click"
                                        Cursor="Hand"
                                        ToolTip="Import application settings from file"/>
                                <Button Content="Export Settings"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuExportSettings_Click"
                                        Cursor="Hand"
                                        ToolTip="Export application settings to file"/>
                                <Button Content="Grid Layouts..."
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuGridLayouts_Click"
                                        Cursor="Hand"
                                        ToolTip="Save and apply custom column layouts"/>
                                <Button Content="Plugin Manager..."
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuPluginManager_Click"
                                        Cursor="Hand"
                                        ToolTip="Install, update, or remove project-specific plugin packages"/>
                                <Button Content="Theme..."
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuTheme_Click"
                                        Cursor="Hand"
                                        ToolTip="Choose between Dark and Light application themes"/>
                                <Button Content="See Release Notes"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuReleaseNotes_Click"
                                        Cursor="Hand"
                                        ToolTip="View features and changes in each release"/>

                                <Separator Background="{DynamicResource BorderColor}" Margin="5,2"/>
                                <Button Content="About Vantage: Milestone"
                                        Background="Transparent"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        HorizontalContentAlignment="Left"
                                        Click="MenuAbout_Click"
                                        Cursor="Hand"
                                        ToolTip="Application version and information"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <Button x:Name="btnMinimize"
                            Content="─"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="46"
                            FontSize="16"
                            Click="BtnMinimize_Click"
                            ToolTip="Minimize"/>

                    <Button x:Name="btnMaximize"
                            Content="☐"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Width="46"
                            FontSize="16"
                            Click="BtnMaximize_Click"
                            ToolTip="Maximize"/>

                    <Button x:Name="btnClose"
                            Width="46"
                            Click="BtnClose_Click"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent">
                                    <TextBlock Text="✕"
                                               FontSize="16"
                                               Foreground="{DynamicResource ToolbarForeground}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                        <Setter TargetName="border" Property="TextBlock.Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
                    

            </Grid>
        </Border>

        <!-- CONTENT AREA WITH SIDEBAR -->
        <Border Grid.Row="1" Background="{DynamicResource BackgroundColor}">
            <Grid x:Name="ContentGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="SplitterColumn" Width="0"/>
                    <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <!-- Main Content -->
                <ContentControl x:Name="ContentArea" Grid.Column="0"/>

                <!-- GridSplitter (only visible when sidebar open) -->
                <GridSplitter x:Name="SidebarSplitter"
                              Grid.Column="1"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource BorderColor}"
                              Visibility="Collapsed"
                              Cursor="SizeWE"
                              DragCompleted="SidebarSplitter_DragCompleted"/>

                <!-- Side Panel -->
                <views:SidePanelView x:Name="SidePanel"
                             Grid.Column="2"
                             Visibility="Collapsed"/>
            </Grid>
        </Border>
        <!-- STATUS BAR -->
        <Border Grid.Row="2"
        Background="{DynamicResource StatusBarBackground}"
        BorderBrush="{DynamicResource BorderColor}"
        BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                   x:Name="txtAppVersion"
                   Text="VANTAGE: Milestone v1.0.0"
                   Foreground="{DynamicResource AccentColor}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="10,0,20,0"/>

                <TextBlock Grid.Column="1"
                   x:Name="txtCurrentUser"
                   Text="User: Steve.Amalfitano"
                   Foreground="{DynamicResource StatusBarForeground}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   Margin="0,0,20,0"/>

                <TextBlock Grid.Column="3"
                   x:Name="txtLastSyncsd"
                   Text="Last Sync: Never"
                   Foreground="{DynamicResource StatusBarForeground}"
                   FontSize="11"
                   VerticalAlignment="Center"
                   Margin="0,0,20,0"/>
            </Grid>
        </Border>
        <!-- Modern Loading Overlay for Excel Imports -->
        <Grid x:Name="LoadingOverlay"
              Grid.RowSpan="3"
              Background="{DynamicResource OverlayBackground}"
              Visibility="Collapsed"
              Panel.ZIndex="1000">
            <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <!-- Syncfusion Busy Indicator -->
                <syncfusion:SfBusyIndicator x:Name="BusyIndicator"
                                    IsBusy="True"
                                    AnimationType="DualRing"
                                    ViewboxWidth="80"
                                    ViewboxHeight="80"
                                    Foreground="{DynamicResource AccentColor}"/>
                <!-- Loading Text -->
                <TextBlock x:Name="txtLoadingMessage"
                   Text="Importing Excel File..."
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource OverlayText}"
                   HorizontalAlignment="Center"
                   Margin="0,30,0,10"/>
                <!-- Progress Text -->
                <TextBlock x:Name="txtLoadingProgress"
                   Text="0 of 0 records"
                   FontSize="14"
                   Foreground="{DynamicResource OverlayTextSecondary}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>
                <!-- Progress Bar -->
                <syncfusion:SfLinearProgressBar x:Name="LoadingProgressBar"
                     Width="300"
                     Height="8"
                     IsIndeterminate="True"
                     ProgressColor="{DynamicResource ProgressBarAccent}"
                     TrackColor="{DynamicResource ProgressBarTrackColor}"/>
            </StackPanel>
        </Grid>

    </Grid>
</syncfusion:ChromelessWindow>
