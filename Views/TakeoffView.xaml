<UserControl x:Class="VANTAGE.Views.TakeoffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="{DynamicResource BackgroundColor}">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="AI Takeoff"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{DynamicResource AccentColor}"
                   Margin="0,0,0,20"/>

        <!-- Config + File Selection (half-width) -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Config Selection -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Config:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <syncfusion:ComboBoxAdv x:Name="cboConfig"
                              Grid.Row="0" Grid.Column="1"
                              Height="28"
                              FontSize="12"
                              SelectionChanged="CboConfig_SelectionChanged"
                              ToolTip="Select the crop region config for this batch"/>
                    <Button x:Name="btnEditConfig"
                            Grid.Row="0" Grid.Column="2"
                            Content="Edit"
                            Width="70"
                            Height="28"
                            Margin="8,0,0,0"
                            FontSize="11"
                            IsEnabled="False"
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            Click="BtnEditConfig_Click"
                            ToolTip="Edit the selected crop region config"/>
                    <Button x:Name="btnRefreshConfigs"
                            Grid.Row="0" Grid.Column="3"
                            Content="Refresh"
                            Width="70"
                            Height="28"
                            Margin="8,0,0,0"
                            FontSize="11"
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            Click="BtnRefreshConfigs_Click"
                            ToolTip="Reload config list from S3"/>

                    <!-- Drawing Files -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Drawings:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtFileCount"
                               Grid.Row="2" Grid.Column="1"
                               Text="No files selected"
                               FontSize="12"
                               Opacity="0.8"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnSelectFiles"
                            Grid.Row="2" Grid.Column="2"
                            Content="Select Files..."
                            Width="90"
                            Height="28"
                            Margin="8,0,0,0"
                            FontSize="11"
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            Click="BtnSelectFiles_Click"
                            ToolTip="Select PDF drawing files to process"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button x:Name="btnProcess"
                    Content="PROCESS BATCH"
                    Style="{StaticResource RoundedButtonStyle}"
                    Padding="20,8"
                    FontSize="12"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ActionButtonForeground}"
                    BorderThickness="0"
                    Click="BtnProcess_Click"
                    ToolTip="Upload drawings and start AI takeoff extraction">
                <Button.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                      Opacity="{DynamicResource ButtonShadowOpacity}"
                                      Color="{DynamicResource ButtonShadowColor}"/>
                </Button.Effect>
            </Button>

            <Button x:Name="btnDownload"
                    Content="DOWNLOAD EXCEL"
                    Style="{StaticResource RoundedButtonStyle}"
                    Padding="20,8"
                    Margin="12,0,0,0"
                    FontSize="12"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Visibility="Collapsed"
                    Click="BtnDownload_Click"
                    ToolTip="Download the output Excel file from S3">
                <Button.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                      Opacity="{DynamicResource ButtonShadowOpacity}"
                                      Color="{DynamicResource ButtonShadowColor}"/>
                </Button.Effect>
            </Button>

            <Button x:Name="btnManageDrawings"
                    Content="MANAGE DRAWINGS"
                    Style="{StaticResource RoundedButtonStyle}"
                    Padding="20,8"
                    Margin="12,0,0,0"
                    FontSize="12"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnManageDrawings_Click"
                    ToolTip="View and manage drawings stored in S3 for the selected config">
                <Button.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                      Opacity="{DynamicResource ButtonShadowOpacity}"
                                      Color="{DynamicResource ButtonShadowColor}"/>
                </Button.Effect>
            </Button>
        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="3"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Status"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="txtStatus"
                           Text="Select a config and drawing files to begin"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Results Summary -->
        <Border Grid.Row="4"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16"
                Margin="0,0,0,16"
                Visibility="Collapsed"
                x:Name="resultsPanel">
            <StackPanel>
                <TextBlock Text="Results"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <!-- Summary Stats -->
                <StackPanel x:Name="summaryPanel" Margin="0,0,0,12"/>

                <!-- Drawings Expander -->
                <Expander x:Name="drawingsExpander"
                          Header="Drawings Processed"
                          IsExpanded="False"
                          Foreground="{DynamicResource ForegroundColor}"
                          Margin="0,0,0,8">
                    <StackPanel x:Name="drawingsListPanel" Margin="16,8,0,0"/>
                </Expander>

                <!-- Connections by Type -->
                <Expander x:Name="connTypeExpander"
                          Header="Connections by Type"
                          IsExpanded="False"
                          Foreground="{DynamicResource ForegroundColor}"
                          Margin="0,0,0,8">
                    <StackPanel x:Name="connTypePanel" Margin="16,8,0,0"/>
                </Expander>

                <!-- Connections by Size -->
                <Expander x:Name="connSizeExpander"
                          Header="Connections by Size"
                          IsExpanded="False"
                          Foreground="{DynamicResource ForegroundColor}"
                          Margin="0,0,0,8">
                    <StackPanel x:Name="connSizePanel" Margin="16,8,0,0"/>
                </Expander>

                <!-- Components by Type -->
                <Expander x:Name="compTypeExpander"
                          Header="Components by Type"
                          IsExpanded="False"
                          Foreground="{DynamicResource ForegroundColor}"
                          Margin="0,0,0,8">
                    <StackPanel x:Name="compTypePanel" Margin="16,8,0,0"/>
                </Expander>

                <!-- Connections by Drawing -->
                <Expander x:Name="connDrawingExpander"
                          Header="Connections by Drawing"
                          IsExpanded="False"
                          Foreground="{DynamicResource ForegroundColor}"
                          Margin="0,0,0,8">
                    <StackPanel x:Name="connDrawingPanel" Margin="16,8,0,0"/>
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
