<UserControl x:Class="VANTAGE.Views.TakeoffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             Background="{DynamicResource BackgroundColor}">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="40,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="AI Takeoff"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="{DynamicResource AccentColor}"
                   Margin="0,0,0,20"/>

        <!-- Config + File Selection (half-width) -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Batch Name -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Batch Name:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="txtBatchName"
                             Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                             Height="28"
                             FontSize="12"
                             VerticalContentAlignment="Center"
                             Padding="4,0"
                             Background="{DynamicResource ControlBackground}"
                             Foreground="{DynamicResource ForegroundColor}"
                             BorderBrush="{DynamicResource BorderColor}"
                             ToolTip="Optional batch name — leave blank for auto-generated name"/>

                    <!-- Config Selection -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Config:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <syncfusion:ComboBoxAdv x:Name="cboConfig"
                              Grid.Row="2" Grid.Column="1"
                              Height="28"
                              FontSize="12"
                              SelectionChanged="CboConfig_SelectionChanged"
                              ToolTip="Select the crop region config for this batch"/>
                    <Button x:Name="btnEditConfig"
                            Grid.Row="2" Grid.Column="2"
                            Content="Edit"
                            Width="90"
                            Height="28"
                            Margin="8,0,0,0"
                            FontSize="11"
                            IsEnabled="False"
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource SidebarButtonBorder}"
                            BorderThickness="1"
                            Click="BtnEditConfig_Click"
                            ToolTip="Edit the selected crop region config">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                              Opacity="{DynamicResource ButtonShadowOpacity}"
                                              Color="{DynamicResource ButtonShadowColor}"/>
                        </Button.Effect>
                    </Button>
                    <Button x:Name="btnRefreshConfigs"
                            Grid.Row="2" Grid.Column="3"
                            Content="Refresh"
                            Width="70"
                            Height="28"
                            Margin="8,0,0,0"
                            FontSize="11"
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource SidebarButtonBorder}"
                            BorderThickness="1"
                            Click="BtnRefreshConfigs_Click"
                            ToolTip="Reload config list from S3">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                              Opacity="{DynamicResource ButtonShadowOpacity}"
                                              Color="{DynamicResource ButtonShadowColor}"/>
                        </Button.Effect>
                    </Button>

                    <!-- Drawing Files -->
                    <TextBlock Grid.Row="4" Grid.Column="0"
                               Text="Drawings:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtFileCount"
                               Grid.Row="4" Grid.Column="1"
                               Text="No files selected"
                               FontSize="12"
                               Opacity="0.8"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnSelectFiles"
                            Grid.Row="4" Grid.Column="2"
                            Content="Select Files..."
                            Width="90"
                            Height="28"
                            Margin="8,0,0,0"
                            FontSize="11"
                            Background="{DynamicResource ControlBackground}"
                            Foreground="{DynamicResource ForegroundColor}"
                            BorderBrush="{DynamicResource SidebarButtonBorder}"
                            BorderThickness="1"
                            Click="BtnSelectFiles_Click"
                            ToolTip="Select PDF drawing files to process">
                        <Button.Effect>
                            <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                              Opacity="{DynamicResource ButtonShadowOpacity}"
                                              Color="{DynamicResource ButtonShadowColor}"/>
                        </Button.Effect>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Rate + ROC Selection (half-width) -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource ControlBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Unit Rates:"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <syncfusion:ComboBoxAdv x:Name="cboUnitRates"
                              Grid.Row="0" Grid.Column="1"
                              Height="28"
                              FontSize="12"
                              SelectionChanged="CboUnitRates_SelectionChanged"
                              ToolTip="Select project-specific unit rates or use the default embedded rate sheet"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,16">
            <Button x:Name="btnProcess"
                    Content="PROCESS BATCH"
                    Style="{StaticResource RoundedButtonStyle}"
                    Padding="20,8"
                    FontSize="12"
                    Background="{DynamicResource StatusGreenBgBtn}"
                    Foreground="{DynamicResource StatusGreenFgBtn}"
                    BorderThickness="0"
                    Click="BtnProcess_Click"
                    ToolTip="Upload drawings and start AI takeoff extraction">
                <Button.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                      Opacity="{DynamicResource ButtonShadowOpacity}"
                                      Color="{DynamicResource ButtonShadowColor}"/>
                </Button.Effect>
            </Button>

            <Button x:Name="btnCancel"
                    Content="CANCEL"
                    Style="{StaticResource RoundedButtonStyle}"
                    Padding="20,8"
                    FontSize="12"
                    Visibility="Collapsed"
                    Background="{DynamicResource StatusRedBgBtn}"
                    Foreground="{DynamicResource StatusRedFgBtn}"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    ToolTip="Cancel the current batch processing">
                <Button.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                      Opacity="{DynamicResource ButtonShadowOpacity}"
                                      Color="{DynamicResource ButtonShadowColor}"/>
                </Button.Effect>
            </Button>

            <Button x:Name="btnPreviousBatches"
                    Content="PREVIOUS BATCHES"
                    Style="{StaticResource RoundedButtonStyle}"
                    Padding="20,8"
                    Margin="12,0,0,0"
                    FontSize="12"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnPreviousBatches_Click"
                    ToolTip="Download results from previously processed batches">
                <Button.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                      Opacity="{DynamicResource ButtonShadowOpacity}"
                                      Color="{DynamicResource ButtonShadowColor}"/>
                </Button.Effect>
            </Button>

        </StackPanel>

        <!-- Options -->
        <CheckBox x:Name="chkSendMissedToAdmin"
                  Grid.Row="4"
                  Content="Send Missed Makeups and Rates to Admin"
                  IsChecked="True"
                  FontSize="12"
                  Foreground="{DynamicResource ForegroundColor}"
                  Margin="0,0,0,16"
                  ToolTip="When checked, emails the takeoff Excel to administrators if there are missed fitting makeups or unmatched rates"/>

        <!-- Status -->
        <Border Grid.Row="5"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16"
                Margin="0,0,0,16"
                MaxHeight="300">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Status"
                           Grid.Row="0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtStatus"
                               Text="Select a config and drawing files to begin"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>
    </ScrollViewer>
</UserControl>
