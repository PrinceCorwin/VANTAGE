<Window x:Class="VANTAGE.Dialogs.ResetUserSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset User Settings"
        Icon="pack://application:,,,/Assets/Images/System/AppIcon.ico"
        Width="640"
        Height="620"
        MinWidth="480"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundColor}"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="Reset User Settings"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource ForegroundColor}"
                   Margin="0,0,0,8"/>

        <!-- Intro -->
        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextColorSecondary}"
                   FontSize="12"
                   Margin="0,0,0,12">
            <Run Text="Check one or more groups below to reset them to default values. Settings managed elsewhere (theme, saved layouts, import profiles, filters, Analysis chart filters, etc.) are not included here — use the corresponding manager dialog for those."/>
        </TextBlock>

        <!-- Scrollable checkbox list -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                Padding="0"
                Margin="0,0,0,15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
                <ItemsControl x:Name="groupsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      ToolTip="{Binding Tooltip}"
                                      Margin="0,6,0,6"
                                      Foreground="{DynamicResource ForegroundColor}">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundColor}"/>
                                    <TextBlock Text="{Binding MemberSummary}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextColorSecondary}"/>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnReset"
                    Content="Reset Selected"
                    Width="140"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="{DynamicResource AccentColor}"
                    Foreground="White"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Click="BtnReset_Click"
                    IsDefault="True"/>
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="32"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
