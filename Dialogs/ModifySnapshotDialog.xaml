<Window x:Class="VANTAGE.Dialogs.ModifySnapshotDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Modify Snapshot"
        Height="600"
        Width="1100"
        MinHeight="400"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="txtHeader"
                       Text="Edit Snapshot"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="Edits only affect this historical snapshot on Azure. Live Activities and sync state are not modified."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Grid -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfSnapshot"
                                       AutoGenerateColumns="True"
                                       AllowEditing="True"
                                       AllowFiltering="True"
                                       AllowSorting="True"
                                       AllowResizingColumns="True"
                                       ColumnSizer="SizeToHeader"
                                       SelectionMode="Single"
                                       NavigationMode="Cell"
                                       EditTrigger="OnTap"
                                       ShowRowHeader="False"
                                       GridLinesVisibility="Both"
                                       HeaderRowHeight="32"
                                       RowHeight="26"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       AutoGeneratingColumn="SfSnapshot_AutoGeneratingColumn"
                                       CurrentCellEndEdit="SfSnapshot_CurrentCellEndEdit"/>

                <!-- Busy overlay -->
                <Border x:Name="busyOverlay"
                        Background="{DynamicResource OverlayBackground}"
                        Visibility="Collapsed"
                        Panel.ZIndex="1000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <syncfusion:SfBusyIndicator IsBusy="True"
                                                    AnimationType="DualRing"
                                                    ViewboxWidth="72"
                                                    ViewboxHeight="72"
                                                    Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock x:Name="txtBusyMessage"
                                   Text="Loading..."
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OverlayText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"/>
            <Button x:Name="btnSave"
                    Content="Save"
                    Width="120"
                    Height="35"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    IsEnabled="False"
                    ToolTip="Save edits back to the Azure snapshot. Live Activities are not affected."
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
