<Window x:Class="VANTAGE.Dialogs.ManageSnapshotsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Manage My Snapshots"
        Height="550"
        Width="780"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        MinHeight="400"
        MinWidth="600"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Manage Snapshots"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="All users' snapshots are listed. Delete, Modify, and Revert are restricted to your own snapshots."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- User Info -->
        <StackPanel Grid.Row="2">
            <TextBlock x:Name="txtUserInfo"
                       Text="Logged in as: username"
                       Foreground="{DynamicResource ForegroundColor}"
                       FontSize="12"/>
        </StackPanel>

        <!-- Snapshots Grid -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource ControlBorder}"
                BorderThickness="1"
                Background="{DynamicResource ControlBackground}"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfSnapshots"
                                       AutoGenerateColumns="False"
                                       AllowEditing="True"
                                       AllowFiltering="True"
                                       AllowSorting="True"
                                       AllowResizingColumns="True"
                                       ColumnSizer="Auto"
                                       SelectionMode="Single"
                                       ShowRowHeader="False"
                                       GridLinesVisibility="Horizontal"
                                       HeaderRowHeight="32"
                                       RowHeight="28"
                                       Background="Transparent"
                                       BorderThickness="0">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridCheckBoxColumn MappingName="IsSelected"
                                                       HeaderText=""
                                                       Width="40"
                                                       AllowFiltering="False"
                                                       AllowSorting="False"/>
                        <syncfusion:GridTextColumn MappingName="Username"
                                                   HeaderText="Username"
                                                   Width="140"
                                                   AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="ProjectID"
                                                   HeaderText="Project ID"
                                                   Width="110"
                                                   AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="WeekEndDateDisplay"
                                                   HeaderText="Week Ending"
                                                   Width="120"
                                                   AllowEditing="False"/>
                        <syncfusion:GridNumericColumn MappingName="SnapshotCount"
                                                      HeaderText="Count"
                                                      Width="70"
                                                      NumberDecimalDigits="0"
                                                      AllowEditing="False"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <!-- Empty State -->
                <TextBlock x:Name="txtNoSnapshots"
                           Text="No snapshots found."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ForegroundColor}"
                           Opacity="0.6"
                           Visibility="Collapsed"/>

                <!-- Loading State -->
                <StackPanel x:Name="pnlLoading"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="Loading snapshots..."
                               Foreground="{DynamicResource ForegroundColor}"
                               Opacity="0.6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Selection Summary -->
        <TextBlock x:Name="txtSelectionSummary"
                   Grid.Row="5"
                   Text="0 group(s) selected (0 snapshots)"
                   Foreground="{DynamicResource ForegroundColor}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,10,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"/>
            <Button x:Name="btnDelete"
                    Content="Delete Selected"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ButtonDangerBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ButtonDangerBorder}"
                    BorderThickness="1"
                    IsEnabled="False"
                    ToolTip="Delete your selected snapshot weeks"
                    Click="BtnDelete_Click"/>
            <Button x:Name="btnModify"
                    Content="Modify Selected"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    IsEnabled="False"
                    ToolTip="Edit values in the selected snapshot week without affecting current activities"
                    Click="BtnModify_Click"/>
            <Button x:Name="btnRevert"
                    Content="Revert To Selected"
                    Width="140"
                    Height="35"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    IsEnabled="False"
                    ToolTip="Restore your activities to the state captured in the selected snapshot"
                    Click="BtnRevert_Click"/>
        </StackPanel>
    </Grid>
</Window>
