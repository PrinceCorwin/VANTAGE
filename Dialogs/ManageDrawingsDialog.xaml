<Window x:Class="VANTAGE.Dialogs.ManageDrawingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Manage Drawings"
        Height="500"
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResizeWithGrip"
        MinHeight="350"
        MinWidth="500"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Manage S3 Drawings"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock x:Name="txtSubtitle"
                       Text="Select a config to view its drawings in S3"
                       FontSize="12"
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Config Selector -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Config:"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <syncfusion:ComboBoxAdv x:Name="cboConfig"
                      Grid.Column="1"
                      Height="28"
                      FontSize="12"
                      SelectionChanged="CboConfig_SelectionChanged"
                      ToolTip="Select a config to view its drawings"/>
            <Button x:Name="btnRefresh"
                    Grid.Column="2"
                    Content="Refresh"
                    Width="70"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Click="BtnRefresh_Click"
                    ToolTip="Reload drawing list from S3"/>
        </Grid>

        <!-- Drawing List -->
        <ListView x:Name="lstDrawings"
                  Grid.Row="4"
                  Background="{DynamicResource ControlBackground}"
                  Foreground="{DynamicResource ForegroundColor}"
                  BorderBrush="{DynamicResource BorderColor}"
                  BorderThickness="1"
                  SelectionMode="Extended"
                  ToolTip="Select drawings to delete (Ctrl+Click for multiple)">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="File Name" Width="300"
                                    DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="Size" Width="80"
                                    DisplayMemberBinding="{Binding SizeDisplay}"/>
                    <GridViewColumn Header="Last Modified" Width="160"
                                    DisplayMemberBinding="{Binding LastModifiedDisplay}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Status -->
        <TextBlock x:Name="txtStatus"
                   Grid.Row="6"
                   Text=""
                   FontSize="12"
                   Foreground="{DynamicResource ForegroundColor}"
                   Opacity="0.8"
                   TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnDelete"
                    Content="Delete Selected"
                    Width="120"
                    Height="30"
                    Margin="0,0,8,0"
                    IsEnabled="False"
                    Click="BtnDelete_Click"
                    ToolTip="Delete the selected drawing(s) from S3"/>
            <Button x:Name="btnClose"
                    Content="Close"
                    Width="80"
                    Height="30"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
