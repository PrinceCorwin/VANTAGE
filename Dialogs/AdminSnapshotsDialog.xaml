<Window x:Class="VANTAGE.Dialogs.AdminSnapshotsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        xmlns:busy="clr-namespace:Syncfusion.Windows.Controls.Notification;assembly=Syncfusion.SfBusyIndicator.WPF"
        Title="Admin: Manage Snapshots Table"
        Height="550"
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        MinHeight="400"
        MinWidth="500"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Manage Progress Snapshots" 
                       FontWeight="SemiBold" 
                       FontSize="16" 
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="View and delete snapshots for any user. Grouped by User, Project, and Week."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.6"
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Snapshots List -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfSnapshots"
                                       AutoGenerateColumns="False"
                                       AllowEditing="True"
                                       AllowFiltering="True"
                                       AllowSorting="True"
                                       AllowResizingColumns="True"
                                       ColumnSizer="Auto"
                                       SelectionMode="Extended"
                                       ShowRowHeader="False"
                                       GridLinesVisibility="Horizontal"
                                       HeaderRowHeight="32"
                                       RowHeight="28"
                                       Background="Transparent"
                                       BorderThickness="0">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridCheckBoxColumn MappingName="IsSelected"
                                                       HeaderText=""
                                                       Width="40"
                                                       AllowFiltering="False"
                                                       AllowSorting="False"/>
                        <syncfusion:GridTextColumn MappingName="Username"
                                                   HeaderText="Username"
                                                   Width="120"
                                                   AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="ProjectID"
                                                   HeaderText="Project ID"
                                                   Width="100"
                                                   AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="WeekEndDateDisplay"
                                                   HeaderText="Week Ending"
                                                   Width="120"
                                                   AllowEditing="False"/>
                        <syncfusion:GridNumericColumn MappingName="SnapshotCount"
                                                      HeaderText="Count"
                                                      Width="70"
                                                      NumberDecimalDigits="0"
                                                      AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="IsUploadedDisplay"
                                                   HeaderText="Uploaded"
                                                   Width="80"
                                                   AllowEditing="False"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <!-- No Snapshots Message -->
                <TextBlock x:Name="txtNoSnapshots"
                           Text="No snapshots found in database."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ForegroundColor}"
                           Opacity="0.6"
                           Visibility="Collapsed"/>

                <!-- Loading State -->
                <StackPanel x:Name="pnlLoading"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="Loading snapshots..."
                               Foreground="{DynamicResource ForegroundColor}"
                               Opacity="0.6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Selection Summary and Select All -->
        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button x:Name="btnSelectAll"
                        Content="Select All"
                        Width="80"
                        Height="28"
                        Margin="0,0,10,0"
                        Background="{DynamicResource ControlBackground}"
                        Foreground="{DynamicResource ForegroundColor}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        Click="BtnSelectAll_Click"/>
                <Button x:Name="btnSelectNone"
                        Content="Select None"
                        Width="80"
                        Height="28"
                        Background="{DynamicResource ControlBackground}"
                        Foreground="{DynamicResource ForegroundColor}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        Click="BtnSelectNone_Click"/>
            </StackPanel>
            <TextBlock x:Name="txtSelectionSummary"
                       Text="0 groups selected (0 snapshots)"
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </DockPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnUploadToProgressLog"
                    Content="Upload to Progress Log"
                    Width="160"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    IsEnabled="False"
                    ToolTip="Upload selected snapshots to VANTAGE_global_ProgressLog on Azure"
                    Click="BtnUploadToProgressLog_Click"/>
            <Button x:Name="btnDeleteAll"
                    Content="Delete ALL Snapshots"
                    Width="150"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ButtonDangerBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ButtonDangerBorder}"
                    BorderThickness="1"
                    Click="BtnDeleteAll_Click"/>
            <Button x:Name="btnCancel"
                    Content="Close"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"/>
            <Button x:Name="btnDelete"
                    Content="Delete Selected"
                    Width="120"
                    Height="35"
                    Background="{DynamicResource ButtonDangerBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ButtonDangerBorder}"
                    BorderThickness="1"
                    IsEnabled="False"
                    Click="BtnDelete_Click"/>
        </StackPanel>

        <!-- Loading Overlay for operations -->
        <Border x:Name="pnlOperationLoading"
                Grid.Row="0"
                Grid.RowSpan="6"
                Background="{DynamicResource OverlayBackground}"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <busy:SfBusyIndicator IsBusy="True"
                                      AnimationType="DoubleCircle"
                                      Foreground="{DynamicResource ForegroundColor}"
                                      Width="60"
                                      Height="60"/>
                <TextBlock x:Name="txtOperationStatus"
                           Text="Processing..."
                           Foreground="{DynamicResource ForegroundColor}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>