<Window x:Class="VANTAGE.Dialogs.ProjectSpecificFunctionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Project Specific Functions"
        Height="450"
        Width="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        MinHeight="350"
        MinWidth="650"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Project Specific Functions"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="Select a project-specific function and click Run."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="2"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfFunctions"
                                       AutoGenerateColumns="False"
                                       AllowEditing="False"
                                       AllowFiltering="False"
                                       AllowSorting="True"
                                       AllowResizingColumns="True"
                                       SelectionMode="Single"
                                       NavigationMode="Row"
                                       ShowRowHeader="False"
                                       GridLinesVisibility="Horizontal"
                                       HeaderRowHeight="32"
                                       RowHeight="28"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       SelectionChanged="SfFunctions_SelectionChanged">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn MappingName="Project"
                                                   HeaderText="Project"
                                                   Width="230"
                                                   AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="Description"
                                                   HeaderText="Description"
                                                   ColumnSizer="Star"
                                                   AllowEditing="False"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <TextBlock x:Name="txtNoFunctions"
                           Text="No project-specific functions are available."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ForegroundColor}"
                           Opacity="0.6"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <TextBlock x:Name="txtSelectionSummary"
                   Grid.Row="4"
                   Text="0 function(s) available"
                   Foreground="{DynamicResource ForegroundColor}"
                   Opacity="0.7"
                   FontSize="12"/>

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnClose"
                    Content="Close"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnClose_Click"/>
            <Button x:Name="btnRun"
                    Content="Run"
                    Width="100"
                    Height="35"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    IsEnabled="False"
                    Click="BtnRun_Click"/>
        </StackPanel>
    </Grid>
</Window>
