<Window x:Class="VANTAGE.Dialogs.ExportOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Options"
        Height="260"
        Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Icon -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="?"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentColor}"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
            <TextBlock Text="Choose which records to export"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Counts -->
        <StackPanel Grid.Row="1" Margin="4,0,0,0">
            <TextBlock Foreground="{DynamicResource ForegroundColor}"
                       FontSize="13"
                       Margin="0,0,0,6">
                <Run Text="&#8226; Filtered Records: "/>
                <Run x:Name="runFilteredCount" FontWeight="SemiBold"/>
            </TextBlock>
            <TextBlock Foreground="{DynamicResource ForegroundColor}"
                       FontSize="13">
                <Run Text="&#8226; All Records: "/>
                <Run x:Name="runAllCount" FontWeight="SemiBold"/>
            </TextBlock>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnFiltered"
                    Content="Filtered"
                    Width="90"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    ToolTip="Export only the filtered records"
                    Click="BtnFiltered_Click"/>
            <Button x:Name="btnAll"
                    Content="All"
                    Width="90"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    ToolTip="Export all records regardless of filters"
                    Click="BtnAll_Click"/>
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="90"
                    Height="32"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    IsCancel="True"
                    ToolTip="Cancel export"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
