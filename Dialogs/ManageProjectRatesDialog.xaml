<Window x:Class="VANTAGE.Dialogs.ManageProjectRatesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Manage Project Rate Sheets"
        Height="500"
        Width="950"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        MinHeight="350"
        MinWidth="550"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Project Rate Sheets"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Foreground="{DynamicResource ForegroundColor}"/>

        <!-- Rate Sets List -->
        <syncfusion:SfDataGrid x:Name="sfGrid"
                               Grid.Row="2"
                               AutoGenerateColumns="False"
                               AllowEditing="False"
                               AllowSorting="True"
                               SelectionMode="Single"
                               GridLinesVisibility="Both"
                               HeaderRowHeight="32"
                               RowHeight="28"
                               Background="{DynamicResource ControlBackground}"
                               Foreground="{DynamicResource ForegroundColor}"
                               BorderBrush="{DynamicResource BorderColor}"
                               BorderThickness="1">
            <syncfusion:SfDataGrid.Columns>
                <syncfusion:GridTextColumn MappingName="ProjectID" HeaderText="Project" Width="120"
                                           ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridTextColumn MappingName="SetName" HeaderText="Rate Set Name" Width="160"
                                           ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridNumericColumn MappingName="RowCount" HeaderText="Rates" Width="65"
                                              NumberDecimalDigits="0"
                                              ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridTextColumn MappingName="CreatedBy" HeaderText="Created By" Width="100"
                                           ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridTextColumn MappingName="CreatedDateDisplay" HeaderText="Created" Width="140"
                                           ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridTextColumn MappingName="UpdatedBy" HeaderText="Updated By" Width="100"
                                           ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridTextColumn MappingName="UpdatedDateDisplay" HeaderText="Updated" Width="140"
                                           ToolTipTemplate="{x:Null}"/>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>

        <!-- Bottom: Buttons + Status -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnUpload"
                    Grid.Column="0"
                    Content="Upload New..."
                    Width="110"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource StatusGreenBgBtn}"
                    Foreground="{DynamicResource StatusGreenFgBtn}"
                    BorderThickness="0"
                    Click="BtnUpload_Click"
                    ToolTip="Upload a new rate sheet from Excel">
                <Button.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                      Opacity="{DynamicResource ButtonShadowOpacity}"
                                      Color="{DynamicResource ButtonShadowColor}"/>
                </Button.Effect>
            </Button>
            <Button x:Name="btnDelete"
                    Grid.Column="1"
                    Content="Delete Selected"
                    Width="110"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="#FF6B6B"
                    BorderBrush="#FF6B6B"
                    BorderThickness="1"
                    Click="BtnDelete_Click"
                    ToolTip="Delete the selected rate set"/>
            <Button x:Name="btnExportTemplate"
                    Grid.Column="2"
                    Content="Export Template"
                    Width="110"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnExportTemplate_Click"
                    ToolTip="Export an empty Excel template with the required columns"/>

            <TextBlock x:Name="txtStatus"
                       Grid.Column="3"
                       Text=""
                       FontSize="12"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Opacity="0.8"/>

            <Button x:Name="btnClose"
                    Grid.Column="4"
                    Content="Close"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnClose_Click"
                    ToolTip="Close this dialog"/>
        </Grid>
    </Grid>
</Window>
