<Window x:Class="VANTAGE.Dialogs.VPvsVtgPrepDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prepare VP Report Before Continuing"
        Icon="pack://application:,,,/Assets/Images/System/AppIcon.ico"
        Width="900"
        Height="720"
        MinWidth="500"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBackground}">

    <!-- Outer grid: scrollable content on top, fixed button row at the bottom -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content region -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,15">
            <StackPanel>

                <TextBlock Text="Before Continuing"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{DynamicResource ForegroundColor}"
                           Margin="0,0,0,12"/>

                <Border Background="{DynamicResource ControlBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        Padding="15"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="The JC Labor Productivity report must be prepped before import:"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   FontSize="13"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextColorSecondary}"
                                   FontSize="12"
                                   Margin="0,0,0,4">
                            <Run Text="• Delete all rows above the phase-code summary table (report headers, top pivot, blank rows)."/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextColorSecondary}"
                                   FontSize="12"
                                   Margin="0,0,0,4">
                            <Run Text="• The &quot;Job&quot; header row must become row 1."/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextColorSecondary}"
                                   FontSize="12">
                            <Run Text="• Delete any leading blank columns so &quot;Job&quot; sits in column A."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        HorizontalAlignment="Left">
                    <Image Source="pack://application:,,,/Assets/Images/Dialogs/vp-vtg-prep.png"
                           Stretch="Uniform"
                           MaxHeight="380"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Do Not Show Again checkbox -->
        <CheckBox Grid.Row="1"
                  x:Name="chkDoNotShowAgain"
                  Content="Do not show this dialog again"
                  ToolTip="You can re-enable this dialog by resetting user settings (Settings menu)"
                  Foreground="{DynamicResource ForegroundColor}"
                  FontSize="12"
                  Margin="0,0,0,15"/>

        <!-- Fixed button row at the bottom -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnOk"
                    Content="OK"
                    Width="100"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="{DynamicResource AccentColor}"
                    Foreground="White"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Click="BtnOk_Click"
                    IsDefault="True"/>
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="32"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
