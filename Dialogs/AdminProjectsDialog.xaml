<Window x:Class="VANTAGE.Dialogs.AdminProjectsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Admin: Edit Projects"
        Height="700"
        Width="850"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        MinHeight="600"
        MinWidth="700"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Projects" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Foreground="{DynamicResource ForegroundColor}"/>

        <!-- Project List -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfProjects"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Foreground="{DynamicResource ForegroundColor}"
                                       AutoGenerateColumns="False"
                                       AllowFiltering="True"
                                       AllowSorting="True"
                                       SortClickAction="DoubleClick"
                                       AllowResizingColumns="True"
                                       AllowDraggingColumns="True"
                                       AllowEditing="False"
                                       ColumnSizer="None"
                                       SelectionMode="Single"
                                       SelectionUnit="Row"
                                       GridLinesVisibility="Both"
                                       HeaderLinesVisibility="Both"
                                       SelectionChanged="SfProjects_SelectionChanged"
                                       FilterChanged="SfProjects_FilterChanged">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn MappingName="ProjectID" HeaderText="Project ID" Width="90"/>
                        <syncfusion:GridTextColumn MappingName="Description" HeaderText="Description" Width="150"/>
                        <syncfusion:GridTextColumn MappingName="ClientName" HeaderText="Client Name" Width="120"/>
                        <syncfusion:GridTextColumn MappingName="Phone" HeaderText="Phone" Width="100"/>
                        <syncfusion:GridTextColumn MappingName="Fax" HeaderText="Fax" Width="100"/>
                        <syncfusion:GridTextColumn MappingName="ClientStreetAddress" HeaderText="Client Address" Width="140"/>
                        <syncfusion:GridTextColumn MappingName="ClientCity" HeaderText="Client City" Width="90"/>
                        <syncfusion:GridTextColumn MappingName="ClientState" HeaderText="Client State" Width="70"/>
                        <syncfusion:GridTextColumn MappingName="ClientZipCode" HeaderText="Client Zip" Width="70"/>
                        <syncfusion:GridTextColumn MappingName="ProjectStreetAddress" HeaderText="Project Address" Width="140"/>
                        <syncfusion:GridTextColumn MappingName="ProjectCity" HeaderText="Project City" Width="90"/>
                        <syncfusion:GridTextColumn MappingName="ProjectState" HeaderText="Project State" Width="70"/>
                        <syncfusion:GridTextColumn MappingName="ProjectZipCode" HeaderText="Project Zip" Width="70"/>
                        <syncfusion:GridTextColumn MappingName="ProjectManager" HeaderText="Project Mgr" Width="100"/>
                        <syncfusion:GridTextColumn MappingName="SiteManager" HeaderText="Site Mgr" Width="100"/>
                        <syncfusion:GridTextColumn MappingName="OM" HeaderText="OM" Width="45"/>
                        <syncfusion:GridTextColumn MappingName="SM" HeaderText="SM" Width="45"/>
                        <syncfusion:GridTextColumn MappingName="EN" HeaderText="EN" Width="45"/>
                        <syncfusion:GridTextColumn MappingName="PM" HeaderText="PM" Width="45"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <StackPanel x:Name="pnlLoading"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="Loading projects..."
                               Foreground="{DynamicResource ForegroundColor}"
                               Opacity="0.6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Project Count -->
        <TextBlock x:Name="txtProjectCount" 
                   Grid.Row="4" 
                   Text="0 project(s)" 
                   Foreground="{DynamicResource ForegroundColor}"
                   Opacity="0.6"
                   FontSize="12"/>

        <!-- Edit Form -->
        <Border Grid.Row="6"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column -->
                    <StackPanel Grid.Column="0">
                        <!-- Project ID and Description -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="100"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Project ID *" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtProjectID" Height="28" Width="100" HorizontalAlignment="Left" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Description" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtDescription" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Client Info -->
                        <TextBlock Text="Client Information" Foreground="{DynamicResource ForegroundColor}" FontWeight="SemiBold" FontSize="13" Margin="0,15,0,8"/>

                        <TextBlock Text="Client Name" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtClientName" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Phone" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtPhone" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Fax" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtFax" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Street Address" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,8,0,5"/>
                        <TextBox x:Name="txtClientStreetAddress" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="City" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtClientCity" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="State" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtClientState" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Zip" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtClientZipCode" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="2">
                        <!-- Management -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Project Manager" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtProjectManager" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Site Manager" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtSiteManager" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Project Site -->
                        <TextBlock Text="Project Site" Foreground="{DynamicResource ForegroundColor}" FontWeight="SemiBold" FontSize="13" Margin="0,15,0,8"/>

                        <TextBlock Text="Street Address" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtProjectStreetAddress" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="City" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtProjectCity" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="State" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtProjectState" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Zip" Foreground="{DynamicResource ForegroundColor}" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtProjectZipCode" Height="28" FontSize="13" Background="{DynamicResource BackgroundColor}" Foreground="{DynamicResource ForegroundColor}" BorderBrush="{DynamicResource BorderColor}" Padding="5,3"/>
                            </StackPanel>
                        </Grid>

                        <!-- Flags -->
                        <TextBlock Text="Flags" Foreground="{DynamicResource ForegroundColor}" FontWeight="SemiBold" FontSize="13" Margin="0,15,0,8"/>

                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkOM" Content="OM" Foreground="{DynamicResource ForegroundColor}" Margin="0,0,20,0"/>
                            <CheckBox x:Name="chkSM" Content="SM" Foreground="{DynamicResource ForegroundColor}" Margin="0,0,20,0"/>
                            <CheckBox x:Name="chkEN" Content="EN" Foreground="{DynamicResource ForegroundColor}" Margin="0,0,20,0"/>
                            <CheckBox x:Name="chkPM" Content="PM" Foreground="{DynamicResource ForegroundColor}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnNew"
                    Content="New Project"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnNew_Click"/>

            <Button x:Name="btnDelete"
                    Content="Delete"
                    Width="80"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ButtonDangerBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ButtonDangerBorder}"
                    BorderThickness="1"
                    IsEnabled="False"
                    Click="BtnDelete_Click"/>

            <Button x:Name="btnClose"
                    Content="Close"
                    Width="80"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnClose_Click"/>

            <Button x:Name="btnSave"
                    Content="Add Project"
                    Width="110"
                    Height="35"
                    Background="{DynamicResource ButtonSuccessBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ButtonSuccessBorder}"
                    BorderThickness="1"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>