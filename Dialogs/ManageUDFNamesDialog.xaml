<Window x:Class="VANTAGE.Dialogs.ManageUDFNamesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage UDF Names"
        Height="780"
        Width="540"
        MinHeight="450"
        MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Subtitle -->
        <TextBlock Grid.Row="0"
                   Text="Rename UDF column headers shown in the Progress grid. Per-user, per-machine. Leave a Visible Name blank to use the default. Click Save to apply."
                   Foreground="{DynamicResource ForegroundColor}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Opacity="0.85"/>

        <!-- Editor (mirrors ImportTakeoffDialog metadata section) -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource SidebarButtonBorder}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="UDF Column Headers"
                           Foreground="{DynamicResource ForegroundColor}"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Field"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                        <TextBlock Grid.Column="2" Text="Visible Name"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icUDFRows">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FieldName}"
                                                   Foreground="{DynamicResource ForegroundColor}"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>

                                        <TextBox Grid.Column="2"
                                                 Text="{Binding EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 MaxLength="50"
                                                 Height="26"
                                                 FontSize="11"
                                                 VerticalContentAlignment="Center"
                                                 Padding="4,0"
                                                 Background="{DynamicResource ControlBackground}"
                                                 Foreground="{DynamicResource ForegroundColor}"
                                                 BorderBrush="{DynamicResource SidebarButtonBorder}"
                                                 ToolTip="Custom column header (max 50 chars). Blank = use the default name."/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Bottom button row -->
        <Grid Grid.Row="4">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="btnReset"
                        Content="Reset Defaults"
                        Width="120" Height="28" Margin="0,0,8,0"
                        Background="{DynamicResource StatusRedBgBtn}"
                        Foreground="{DynamicResource StatusRedFgBtn}"
                        BorderBrush="{DynamicResource SidebarButtonBorder}"
                        BorderThickness="1"
                        Padding="10,0"
                        FontSize="11"
                        Click="BtnReset_Click"
                        ToolTip="Clear all UDF overrides and revert column headers to their defaults.">
                    <Button.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="6" Direction="315"
                                          Opacity="{DynamicResource ButtonShadowOpacity}"
                                          Color="{DynamicResource ButtonShadowColor}"/>
                    </Button.Effect>
                </Button>
                <Button x:Name="btnExport" Content="Export"
                        Width="80" Height="28" Margin="0,0,8,0"
                        Background="{DynamicResource ControlBackground}"
                        Foreground="{DynamicResource ForegroundColor}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        Click="BtnExport_Click"
                        ToolTip="Export the current editor values to a JSON file."/>
                <Button x:Name="btnImport" Content="Import"
                        Width="80" Height="28" Margin="0,0,8,0"
                        Background="{DynamicResource ControlBackground}"
                        Foreground="{DynamicResource ForegroundColor}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        Click="BtnImport_Click"
                        ToolTip="Import UDF column names from a JSON file into the editor. Click Save to apply."/>
                <Button x:Name="btnSave" Content="Save"
                        Width="80" Height="28"
                        Background="{DynamicResource ControlBackground}"
                        Foreground="{DynamicResource StatusGreen}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        Click="BtnSave_Click"
                        ToolTip="Save the editor values and apply them as the new UDF column headers."/>
            </StackPanel>
            <Button x:Name="btnClose" Content="Close"
                    Width="70" Height="28" HorizontalAlignment="Right"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    Click="BtnClose_Click"
                    ToolTip="Close the dialog."/>
        </Grid>
    </Grid>
</Window>
