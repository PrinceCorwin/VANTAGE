<Window x:Class="VANTAGE.Dialogs.ImportTakeoffDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Import from AI Takeoff"
        Height="300"
        Width="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Import from AI Takeoff"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Foreground="{DynamicResource ForegroundColor}"/>

        <!-- Source Selection -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Source:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"/>

            <RadioButton x:Name="rbFromFile"
                         Grid.Column="1"
                         Content="From File"
                         IsChecked="True"
                         Foreground="{DynamicResource ForegroundColor}"
                         VerticalAlignment="Center"
                         Checked="RbSource_Checked"
                         ToolTip="Import from a local Excel file"/>

            <RadioButton x:Name="rbFromBatch"
                         Grid.Column="3"
                         Content="From Batch"
                         Foreground="{DynamicResource ForegroundColor}"
                         VerticalAlignment="Center"
                         Checked="RbSource_Checked"
                         ToolTip="Import from a previously processed AI Takeoff batch"/>

            <Button x:Name="btnSelectFile"
                    Grid.Column="5"
                    Content="Select File..."
                    Width="90"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnSelectFile_Click"
                    ToolTip="Browse for an Excel (.xlsx) takeoff file"/>

            <Button x:Name="btnBatches"
                    Grid.Column="7"
                    Content="Batches..."
                    Width="90"
                    Height="28"
                    FontSize="11"
                    IsEnabled="False"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnBatches_Click"
                    ToolTip="Browse previously processed AI Takeoff batches"/>
        </Grid>

        <!-- Source Label -->
        <TextBlock x:Name="txtSourceLabel"
                   Grid.Row="4"
                   Text="No file selected"
                   Foreground="{DynamicResource ForegroundColor}"
                   FontSize="11"
                   Opacity="0.6"
                   Margin="60,0,0,0"
                   TextTrimming="CharacterEllipsis"/>

        <!-- ROC Set Selection -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="ROC Set:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       FontSize="13"
                       FontWeight="SemiBold"/>

            <syncfusion:ComboBoxAdv x:Name="cboROCSet"
                       Grid.Column="1"
                       Height="28"
                       FontSize="12"
                       IsEditable="False"
                       SelectionChanged="CboROCSet_SelectionChanged"
                       ToolTip="Select a ROC percentage split set for the import"/>
        </Grid>

        <!-- Import / Cancel Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="90"
                    Height="30"
                    FontSize="12"
                    Background="{DynamicResource StatusRedBgBtn}"
                    Foreground="{DynamicResource StatusRedFgBtn}"
                    BorderThickness="0"
                    Click="BtnCancel_Click"
                    ToolTip="Close without importing"/>
            <Button x:Name="btnImport"
                    Content="Import"
                    Width="90"
                    Height="30"
                    Margin="10,0,0,0"
                    FontSize="12"
                    Background="{DynamicResource StatusGreenBgBtn}"
                    Foreground="{DynamicResource StatusGreenFgBtn}"
                    BorderThickness="0"
                    Click="BtnImport_Click"
                    ToolTip="Import activities from the selected source"/>
        </StackPanel>
    </Grid>
</Window>
