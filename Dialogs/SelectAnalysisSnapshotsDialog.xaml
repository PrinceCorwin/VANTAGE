<Window x:Class="VANTAGE.Dialogs.SelectAnalysisSnapshotsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Select Snapshots for Analysis"
        Height="600"
        Width="900"
        MinHeight="400"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Select Snapshots for Analysis"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="Check the snapshots you want the Analysis summary to aggregate over, then click Apply. Each row is one Submit Week submission by (User, Project, Week Ending). The same UniqueID can appear in multiple snapshots — picking overlapping snapshots will double-count those rows."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Selection toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="btnSelectAll"
                    Content="Select All"
                    Width="90"
                    Height="28"
                    Margin="0,0,8,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnSelectAll_Click"
                    ToolTip="Check the box on every row."/>
            <Button x:Name="btnSelectNone"
                    Content="Select None"
                    Width="90"
                    Height="28"
                    Margin="0,0,16,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnSelectNone_Click"
                    ToolTip="Uncheck the box on every row."/>
            <TextBlock x:Name="txtSelectionCount"
                       Text=""
                       VerticalAlignment="Center"
                       FontSize="12"
                       Opacity="0.7"
                       Foreground="{DynamicResource ForegroundColor}"/>
        </StackPanel>

        <!-- Grid -->
        <Border Grid.Row="4"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfSnapshots"
                                       AutoGenerateColumns="False"
                                       AllowEditing="True"
                                       AllowSorting="True"
                                       AllowFiltering="True"
                                       AllowResizingColumns="True"
                                       SelectionMode="Single"
                                       NavigationMode="Cell"
                                       EditTrigger="OnTap"
                                       ShowRowHeader="False"
                                       GridLinesVisibility="Both"
                                       HeaderRowHeight="32"
                                       RowHeight="26"
                                       Background="Transparent"
                                       BorderThickness="0">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridCheckBoxColumn MappingName="IsSelected" HeaderText="Pick" Width="55" AllowEditing="True"/>
                        <syncfusion:GridTextColumn MappingName="AssignedTo" HeaderText="User" Width="160" AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="ProjectID" HeaderText="Project" Width="160" AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="WeekEndDate" HeaderText="Week Ending" Width="140" AllowEditing="False"/>
                        <syncfusion:GridNumericColumn MappingName="RowCount" HeaderText="Rows" Width="100" AllowEditing="False" NumberDecimalDigits="0"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <!-- Busy overlay -->
                <Border x:Name="busyOverlay"
                        Background="{DynamicResource OverlayBackground}"
                        Visibility="Visible"
                        Panel.ZIndex="1000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <syncfusion:SfBusyIndicator IsBusy="True"
                                                    AnimationType="DualRing"
                                                    ViewboxWidth="72"
                                                    ViewboxHeight="72"
                                                    Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock x:Name="txtBusyMessage"
                                   Text="Loading snapshots from Azure..."
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OverlayText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"
                    ToolTip="Close without changing the current selection."/>
            <Button x:Name="btnApply"
                    Content="Apply"
                    Width="120"
                    Height="35"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    Click="BtnApply_Click"
                    ToolTip="Use the checked snapshots as the source for the Analysis summary aggregation."/>
        </StackPanel>
    </Grid>
</Window>
