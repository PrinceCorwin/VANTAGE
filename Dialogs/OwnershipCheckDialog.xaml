<Window x:Class="VANTAGE.Dialogs.OwnershipCheckDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Ownership Check"
        Height="520"
        Width="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="ActNO Split Ownership Check"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="Queries Azure for any SchedActNOs assigned to multiple users within a project."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Project Selection + Check Button -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Project:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       FontSize="13"/>

            <syncfusion:ComboBoxAdv x:Name="cboProject"
                                     Grid.Column="2"
                                     Height="30"
                                     DisplayMemberPath="Display"
                                     ToolTip="Select the project to check"/>

            <Button x:Name="btnCheck"
                    Grid.Column="4"
                    Content="Check"
                    Width="90"
                    Height="30"
                    Click="BtnCheck_Click"
                    Background="{DynamicResource AccentColor}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Query Azure for split ownership issues"/>
        </Grid>

        <!-- Results -->
        <Border Grid.Row="4"
                BorderBrush="{DynamicResource ControlBorder}"
                BorderThickness="1"
                Background="{DynamicResource ControlBackground}">
            <Grid>
                <!-- Loading state -->
                <StackPanel x:Name="pnlLoading"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <syncfusion:SfBusyIndicator IsBusy="True"
                                                 AnimationType="DualRing"
                                                 Foreground="{DynamicResource AccentColor}"
                                                 Width="40" Height="40"/>
                    <TextBlock Text="Querying Azure..."
                               Foreground="{DynamicResource ForegroundColor}"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Empty state -->
                <TextBlock x:Name="txtEmpty"
                           Text="Select a project and click Check to scan for split ownership."
                           Foreground="{DynamicResource ForegroundColor}"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Visible"/>

                <!-- Results list -->
                <ListView x:Name="lstResults"
                          Visibility="Collapsed"
                          Background="Transparent"
                          Foreground="{DynamicResource ForegroundColor}"
                          BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="SchedActNO" Width="220"
                                            DisplayMemberBinding="{Binding SchedActNO}"/>
                            <GridViewColumn Header="Assigned To" Width="200"
                                            DisplayMemberBinding="{Binding AssignedTo}"/>
                            <GridViewColumn Header="Records" Width="80"
                                            DisplayMemberBinding="{Binding RecordCount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="6">
            <TextBlock x:Name="txtStatus"
                       Text=""
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       FontSize="12"/>

            <Button x:Name="btnClose"
                    Content="Close"
                    Width="90"
                    Height="30"
                    HorizontalAlignment="Right"
                    Click="BtnClose_Click"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
