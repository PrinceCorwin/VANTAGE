<Window x:Class="VANTAGE.Dialogs.ManageROCRatesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Manage ROC Rate Sets"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        MinHeight="450"
        MinWidth="700"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="ROC Rate Sets"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Foreground="{DynamicResource ForegroundColor}"/>

        <!-- Project + Set Selection -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Project:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"/>
            <syncfusion:ComboBoxAdv x:Name="cboProject"
                       Grid.Column="1"
                       Height="28"
                       FontSize="12"
                       SelectionChanged="CboProject_SelectionChanged"
                       ToolTip="Select a project to view its ROC rate sets"/>

            <TextBlock Grid.Column="3" Text="Set Name:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"/>
            <syncfusion:ComboBoxAdv x:Name="cboSetName"
                       Grid.Column="4"
                       Height="28"
                       FontSize="12"
                       IsEditable="True"
                       SelectionChanged="CboSetName_SelectionChanged"
                       ToolTip="Select an existing set or type a new name"/>

            <Button x:Name="btnLoadSet"
                    Grid.Column="6"
                    Content="Load"
                    Width="70"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnLoadSet_Click"
                    ToolTip="Load the selected set for editing"/>
            <Button x:Name="btnDeleteSet"
                    Grid.Column="7"
                    Content="Delete Set"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="#FF6B6B"
                    BorderBrush="#FF6B6B"
                    BorderThickness="1"
                    Click="BtnDeleteSet_Click"
                    ToolTip="Delete the entire selected set"/>
        </Grid>

        <!-- Data Grid -->
        <syncfusion:SfDataGrid x:Name="sfGrid"
                               Grid.Row="4"
                               AutoGenerateColumns="False"
                               AllowEditing="True"
                               EditTrigger="OnTap"
                               AllowDeleting="False"
                               AllowSorting="False"
                               SelectionMode="Single"
                               NavigationMode="Cell"
                               GridLinesVisibility="Both"
                               HeaderRowHeight="32"
                               RowHeight="28"
                               Background="{DynamicResource ControlBackground}"
                               Foreground="{DynamicResource ForegroundColor}"
                               BorderBrush="{DynamicResource BorderColor}"
                               BorderThickness="1">
            <syncfusion:SfDataGrid.Columns>
                <syncfusion:GridTextColumn MappingName="ROCStep" HeaderText="ROC Step" Width="180"
                                           ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridNumericColumn MappingName="Percentage" HeaderText="Percentage" Width="120"
                                              NumberDecimalDigits="2"
                                              ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridComboBoxColumn MappingName="ShopField" HeaderText="Shop/Field" Width="120"
                                               ItemsSource="{Binding ShopFieldOptions}"
                                               ToolTipTemplate="{x:Null}"/>
                <syncfusion:GridNumericColumn MappingName="SortOrder" HeaderText="Sort Order" Width="100"
                                              NumberDecimalDigits="0"
                                              ToolTipTemplate="{x:Null}"/>
            </syncfusion:SfDataGrid.Columns>
        </syncfusion:SfDataGrid>

        <!-- Bottom: Buttons + Status -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnAddRow"
                    Grid.Column="0"
                    Content="Add Row"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnAddRow_Click"
                    ToolTip="Add a new ROC step row"/>
            <Button x:Name="btnDeleteRow"
                    Grid.Column="1"
                    Content="Delete Row"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnDeleteRow_Click"
                    ToolTip="Delete the selected row"/>
            <Button x:Name="btnSave"
                    Grid.Column="2"
                    Content="Save"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Background="{DynamicResource StatusGreenBgBtn}"
                    Foreground="{DynamicResource StatusGreenFgBtn}"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    ToolTip="Save ROC rate set to Azure"/>

            <TextBlock x:Name="txtStatus"
                       Grid.Column="3"
                       Text=""
                       FontSize="12"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Opacity="0.8"/>

            <Button x:Name="btnClose"
                    Grid.Column="5"
                    Content="Close"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnClose_Click"
                    ToolTip="Close this dialog"/>
        </Grid>
    </Grid>
</Window>
