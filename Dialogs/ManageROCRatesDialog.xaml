<Window x:Class="VANTAGE.Dialogs.ManageROCRatesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Manage ROC Rate Sets"
        Height="600"
        Width="1250"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        MinHeight="450"
        MinWidth="1050"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="ROC Rate Sets"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Foreground="{DynamicResource ForegroundColor}"/>

        <!-- VIEW MODE: Set Selection -->
        <Grid x:Name="pnlViewHeader" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Set:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <syncfusion:ComboBoxAdv x:Name="cboSet"
                       Grid.Column="1"
                       Height="28"
                       FontSize="12"
                       IsEditable="False"
                       SelectionChanged="CboSet_SelectionChanged"
                       ToolTip="Select a ROC rate set to view"/>

            <Button x:Name="btnNewSet"
                    Grid.Column="3"
                    Content="New Set"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnNewSet_Click"
                    ToolTip="Create a new ROC rate set"/>

            <Button x:Name="btnModify"
                    Grid.Column="5"
                    Content="Modify"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnModify_Click"
                    ToolTip="Edit the selected ROC rate set"/>

            <Button x:Name="btnDeleteSet"
                    Grid.Column="7"
                    Content="Delete Set"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="#FF6B6B"
                    BorderBrush="#FF6B6B"
                    BorderThickness="1"
                    Click="BtnDeleteSet_Click"
                    ToolTip="Delete the entire selected set"/>
        </Grid>

        <!-- EDIT MODE: Project + Set Name -->
        <Grid x:Name="pnlEditHeader" Grid.Row="2" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Project:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <syncfusion:ComboBoxAdv x:Name="cboEditProject"
                       Grid.Column="1"
                       Height="28"
                       FontSize="12"
                       IsEditable="False"
                       ToolTip="Select the project for this ROC rate set"/>

            <TextBlock Grid.Column="3" Text="Set Name:"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>
            <TextBox x:Name="txtEditSetName"
                     Grid.Column="4"
                     Height="28"
                     FontSize="12"
                     VerticalContentAlignment="Center"
                     Padding="4,0"
                     Background="{DynamicResource ControlBackground}"
                     Foreground="{DynamicResource ForegroundColor}"
                     BorderBrush="{DynamicResource BorderColor}"
                     ToolTip="Enter a name for this ROC rate set"/>
        </Grid>

        <!-- Data Grid + Component Checklist -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- ROC Steps Grid -->
            <syncfusion:SfDataGrid x:Name="sfGrid"
                                   Grid.Column="0"
                                   AutoGenerateColumns="False"
                                   AllowEditing="False"
                                   EditTrigger="OnTap"
                                   AllowDeleting="False"
                                   AllowSorting="False"
                                   SelectionMode="Single"
                                   NavigationMode="Cell"
                                   GridLinesVisibility="Both"
                                   HeaderRowHeight="32"
                                   RowHeight="28"
                                   Background="{DynamicResource ControlBackground}"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   BorderBrush="{DynamicResource BorderColor}"
                                   BorderThickness="1">
                <syncfusion:SfDataGrid.Columns>
                    <syncfusion:GridTextColumn MappingName="ROCStep" HeaderText="ROC Step" Width="180"
                                               ToolTipTemplate="{x:Null}"/>
                    <syncfusion:GridNumericColumn MappingName="Percentage" HeaderText="Percentage" Width="120"
                                                  NumberDecimalDigits="2"
                                                  ToolTipTemplate="{x:Null}"/>
                    <syncfusion:GridComboBoxColumn MappingName="ShopField" HeaderText="Shop/Field" Width="120"
                                                   ItemsSource="{Binding ShopFieldOptions}"
                                                   ToolTipTemplate="{x:Null}"/>
                    <syncfusion:GridNumericColumn MappingName="SortOrder" HeaderText="Sort Order" Width="100"
                                                  NumberDecimalDigits="0"
                                                  ToolTipTemplate="{x:Null}"/>
                </syncfusion:SfDataGrid.Columns>
            </syncfusion:SfDataGrid>

            <!-- Applicable Components Checklist -->
            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Applicable Components"
                               Foreground="{DynamicResource ForegroundColor}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="10,8,10,4"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,6">
                        <Button x:Name="btnCheckAll"
                                Content="All"
                                Width="40"
                                Height="22"
                                FontSize="10"
                                Background="{DynamicResource ControlBackground}"
                                Foreground="{DynamicResource ForegroundColor}"
                                BorderBrush="{DynamicResource SidebarButtonBorder}"
                                BorderThickness="1"
                                Click="BtnCheckAll_Click"
                                ToolTip="Check all components"/>
                        <Button x:Name="btnUncheckAll"
                                Content="None"
                                Width="40"
                                Height="22"
                                FontSize="10"
                                Margin="4,0,0,0"
                                Background="{DynamicResource ControlBackground}"
                                Foreground="{DynamicResource ForegroundColor}"
                                BorderBrush="{DynamicResource SidebarButtonBorder}"
                                BorderThickness="1"
                                Click="BtnUncheckAll_Click"
                                ToolTip="Uncheck all components"/>
                        <TextBlock x:Name="txtComponentCount"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   FontSize="11"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="6,0,6,6">
                        <ItemsControl x:Name="icComponents">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}"
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              IsEnabled="{Binding IsEnabled}"
                                              Foreground="{DynamicResource ForegroundColor}"
                                              Margin="4,1,0,1"
                                              FontSize="12"
                                              ToolTip="Check to include this component in ROC splits"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Buttons -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Edit mode buttons (hidden in view mode) -->
            <Button x:Name="btnAddRow"
                    Grid.Column="0"
                    Content="Add Row"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Visibility="Collapsed"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnAddRow_Click"
                    ToolTip="Add a new ROC step row"/>
            <Button x:Name="btnDeleteRow"
                    Grid.Column="1"
                    Content="Delete Row"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Visibility="Collapsed"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnDeleteRow_Click"
                    ToolTip="Delete the selected row"/>
            <Button x:Name="btnSave"
                    Grid.Column="2"
                    Content="Save"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Visibility="Collapsed"
                    Background="{DynamicResource StatusGreenBgBtn}"
                    Foreground="{DynamicResource StatusGreenFgBtn}"
                    BorderThickness="0"
                    Click="BtnSave_Click"
                    ToolTip="Save ROC rate set to Azure"/>
            <Button x:Name="btnCancel"
                    Grid.Column="3"
                    Content="Cancel"
                    Width="80"
                    Height="28"
                    Margin="8,0,0,0"
                    FontSize="11"
                    Visibility="Collapsed"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"
                    ToolTip="Discard changes and return to view mode"/>

            <!-- Status text -->
            <TextBlock x:Name="txtStatus"
                       Grid.Column="4"
                       Text=""
                       FontSize="12"
                       Foreground="{DynamicResource ForegroundColor}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Opacity="0.8"/>

            <!-- Close (always visible) -->
            <Button x:Name="btnClose"
                    Grid.Column="6"
                    Content="Close"
                    Width="80"
                    Height="28"
                    FontSize="11"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource SidebarButtonBorder}"
                    BorderThickness="1"
                    Click="BtnClose_Click"
                    ToolTip="Close this dialog"/>
        </Grid>
    </Grid>
</Window>
