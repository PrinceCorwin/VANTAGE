<Window x:Class="VANTAGE.Dialogs.PreviousBatchesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Previous Batches"
        Height="450"
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResizeWithGrip"
        MinHeight="300"
        MinWidth="500"
        WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ControlBorder}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Previous Batches"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="Select a batch to download its takeoff results"
                       FontSize="12"
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Batch List -->
        <ListView x:Name="lstBatches"
                  Grid.Row="2"
                  Background="{DynamicResource ControlBackground}"
                  Foreground="{DynamicResource ForegroundColor}"
                  BorderBrush="{DynamicResource BorderColor}"
                  BorderThickness="1"
                  SelectionMode="Single"
                  MouseDoubleClick="LstBatches_MouseDoubleClick"
                  SelectionChanged="LstBatches_SelectionChanged"
                  ToolTip="Select a batch to download">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Foreground" Value="{DynamicResource ForegroundColor}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ControlBorder}"/>
                        </Trigger>
                    </Style.Triggers>
                    <Style.Resources>
                        <!-- Override system highlight colors -->
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                    </Style.Resources>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Name" Width="160"
                                    DisplayMemberBinding="{Binding BatchName}"/>
                    <GridViewColumn Header="Config" Width="130"
                                    DisplayMemberBinding="{Binding ConfigName}"/>
                    <GridViewColumn Header="Date" Width="170"
                                    DisplayMemberBinding="{Binding DateDisplay}"/>
                    <GridViewColumn Header="Drawings" Width="70"
                                    DisplayMemberBinding="{Binding DrawingDisplay}"/>
                    <GridViewColumn Header="User" Width="100"
                                    DisplayMemberBinding="{Binding Username}"/>
                    <GridViewColumn Header="Status" Width="80"
                                    DisplayMemberBinding="{Binding StatusDisplay}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Status -->
        <TextBlock x:Name="txtStatus"
                   Grid.Row="4"
                   Text=""
                   FontSize="12"
                   Foreground="{DynamicResource ForegroundColor}"
                   Opacity="0.8"
                   TextWrapping="Wrap"/>

        <!-- Buttons -->
        <Grid Grid.Row="6">
            <!-- Admin delete buttons (left) -->
            <StackPanel x:Name="pnlAdminButtons"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Visibility="Collapsed">
                <Button x:Name="btnDeleteSelected"
                        Style="{StaticResource SidebarButtonStyle}"
                        Content="Delete Selected"
                        Height="30"
                        Padding="20,0"
                        Margin="0,0,10,0"
                        FontSize="12"
                        Background="{DynamicResource StatusRedBgBtn}"
                        Foreground="{DynamicResource StatusRedFgBtn}"
                        BorderBrush="{DynamicResource SidebarButtonBorder}"
                        BorderThickness="1"
                        HorizontalContentAlignment="Center"
                        IsEnabled="False"
                        Click="BtnDeleteSelected_Click"
                        ToolTip="Delete the selected batch from AWS"/>
                <Button x:Name="btnDeleteAll"
                        Style="{StaticResource SidebarButtonStyle}"
                        Content="Delete All"
                        Height="30"
                        Padding="20,0"
                        FontSize="12"
                        Background="{DynamicResource StatusRedBgBtn}"
                        Foreground="{DynamicResource StatusRedFgBtn}"
                        BorderBrush="{DynamicResource SidebarButtonBorder}"
                        BorderThickness="1"
                        HorizontalContentAlignment="Center"
                        Click="BtnDeleteAll_Click"
                        ToolTip="Delete all batches from AWS"/>
            </StackPanel>

            <!-- Download/Cancel buttons (right) -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <!-- Rename button (available to all users) -->
                <Button x:Name="btnRename"
                        Style="{StaticResource SidebarButtonStyle}"
                        Content="Rename"
                        Height="30"
                        Padding="20,0"
                        Margin="0,0,10,0"
                        FontSize="12"
                        Background="{DynamicResource StatusInProgressBgBtn}"
                        Foreground="{DynamicResource StatusInProgressFgBtn}"
                        BorderBrush="{DynamicResource SidebarButtonBorder}"
                        BorderThickness="1"
                        HorizontalContentAlignment="Center"
                        IsEnabled="False"
                        Click="BtnRename_Click"
                        ToolTip="Rename the selected batch"/>
                <Button Style="{StaticResource SidebarButtonStyle}"
                        Content="Cancel"
                        Height="30"
                        Padding="20,0"
                        Margin="0,0,10,0"
                        FontSize="12"
                        Background="{DynamicResource StatusRedBgBtn}"
                        Foreground="{DynamicResource StatusRedFgBtn}"
                        BorderBrush="{DynamicResource SidebarButtonBorder}"
                        BorderThickness="1"
                        HorizontalContentAlignment="Center"
                        IsCancel="True"
                        ToolTip="Close without downloading"/>
                <Button x:Name="btnDownload"
                        Style="{StaticResource SidebarButtonStyle}"
                        Content="Download Excel"
                        Height="30"
                        Padding="20,0"
                        FontSize="12"
                        Background="{DynamicResource StatusGreenBgBtn}"
                        Foreground="{DynamicResource StatusGreenFgBtn}"
                        BorderBrush="{DynamicResource SidebarButtonBorder}"
                        BorderThickness="1"
                        HorizontalContentAlignment="Center"
                        IsEnabled="False"
                        Click="BtnDownload_Click"
                        ToolTip="Download the selected batch's takeoff Excel"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
