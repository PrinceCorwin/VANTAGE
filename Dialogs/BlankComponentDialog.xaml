<Window x:Class="VANTAGE.Dialogs.BlankComponentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Missing Components"
        Height="500"
        Width="750"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResizeWithGrip"
        MinHeight="300"
        MinWidth="550"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="The following material rows have no Component value. Enter the component type for each:"
                   Foreground="{DynamicResource ForegroundColor}"
                   FontSize="13"
                   TextWrapping="Wrap"/>

        <!-- Scrollable list of items -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlBorder}"
                BorderThickness="1"
                CornerRadius="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="itemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <!-- Drawing + Description stacked -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DrawingNumber}"
                                               Foreground="{DynamicResource ForegroundColor}"
                                               FontSize="11"
                                               Opacity="0.7"/>
                                    <TextBlock Text="{Binding RawDescription}"
                                               Foreground="{DynamicResource ForegroundColor}"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Component input -->
                                <TextBox Grid.Column="2"
                                         Text="{Binding Component, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="30"
                                         FontSize="13"
                                         Padding="6,4"
                                         MaxLength="10"
                                         CharacterCasing="Upper"
                                         VerticalContentAlignment="Center"
                                         Background="{DynamicResource ControlBackground}"
                                         Foreground="{DynamicResource ControlForeground}"
                                         BorderBrush="{DynamicResource ControlBorder}"
                                         BorderThickness="1"
                                         ToolTip="Enter the component type (e.g. FLG, VLV, STR)"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Skip All"
                    Width="90"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    IsCancel="True"
                    ToolTip="Continue without assigning components"/>

            <Button Content="Apply"
                    Width="90"
                    Height="35"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    IsDefault="True"
                    Click="BtnApply_Click"
                    ToolTip="Write component values to the Material tab and continue"/>
        </StackPanel>
    </Grid>
</Window>
