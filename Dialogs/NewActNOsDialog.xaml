<Window x:Class="VANTAGE.Dialogs.NewActNOsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="New ActNOs from P6"
        Height="600"
        Width="1000"
        MinHeight="400"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock x:Name="txtHeader"
                       Text="New ActNOs from P6"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock x:Name="txtIntro"
                       Text="These SchedActNOs exist in the imported P6 file but not in the snapshot being compared. Select the rows you want to create. Required metadata not in P6 (WorkPackage, PhaseCode, etc.) will be set to 'X' so you can fill them in later."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Project picker -->
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Assign new records to project:"
                       FontWeight="SemiBold"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ForegroundColor}"
                       Margin="0,0,10,0"/>
            <ComboBox x:Name="cmbProject"
                      Width="280"
                      Height="28"
                      Background="{DynamicResource ControlBackground}"
                      Foreground="{DynamicResource ControlForeground}"
                      BorderBrush="{DynamicResource ControlBorder}"
                      ToolTip="One ProjectID is assigned to all selected new records."/>
        </StackPanel>

        <!-- Selection toolbar -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <Button x:Name="btnSelectAll"
                    Content="Select All"
                    Width="90"
                    Height="28"
                    Margin="0,0,8,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnSelectAll_Click"
                    ToolTip="Check the box on every row."/>
            <Button x:Name="btnSelectNone"
                    Content="Select None"
                    Width="90"
                    Height="28"
                    Margin="0,0,16,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnSelectNone_Click"
                    ToolTip="Uncheck the box on every row."/>
            <TextBlock x:Name="txtSelectionCount"
                       Text=""
                       VerticalAlignment="Center"
                       FontSize="12"
                       Opacity="0.7"
                       Foreground="{DynamicResource ForegroundColor}"/>
        </StackPanel>

        <!-- Grid -->
        <Border Grid.Row="6"
                Background="{DynamicResource ControlBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfCandidates"
                                       AutoGenerateColumns="False"
                                       AllowEditing="True"
                                       AllowSorting="True"
                                       AllowResizingColumns="True"
                                       SelectionMode="Single"
                                       NavigationMode="Cell"
                                       EditTrigger="OnTap"
                                       ShowRowHeader="False"
                                       GridLinesVisibility="Both"
                                       HeaderRowHeight="32"
                                       RowHeight="26"
                                       Background="Transparent"
                                       BorderThickness="0">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridCheckBoxColumn MappingName="IsSelected" HeaderText="Pick" Width="55" AllowEditing="True"/>
                        <syncfusion:GridTextColumn MappingName="SchedActNO" HeaderText="SchedActNO" Width="160" AllowEditing="False"/>
                        <syncfusion:GridTextColumn MappingName="Description" HeaderText="Description" Width="320" AllowEditing="True"/>
                        <syncfusion:GridNumericColumn MappingName="BudgetMHs" HeaderText="Budget MHs" Width="110" NumberDecimalDigits="3"/>
                        <syncfusion:GridNumericColumn MappingName="PercentEntry" HeaderText="% Complete" Width="110" NumberDecimalDigits="2"/>
                        <syncfusion:GridDateTimeColumn MappingName="ActStart" HeaderText="ActStart" Width="120" Pattern="ShortDate"/>
                        <syncfusion:GridDateTimeColumn MappingName="ActFin" HeaderText="ActFin" Width="120" Pattern="ShortDate"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <!-- Busy overlay -->
                <Border x:Name="busyOverlay"
                        Background="{DynamicResource OverlayBackground}"
                        Visibility="Collapsed"
                        Panel.ZIndex="1000">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <syncfusion:SfBusyIndicator IsBusy="True"
                                                    AnimationType="DualRing"
                                                    ViewboxWidth="72"
                                                    ViewboxHeight="72"
                                                    Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock x:Name="txtBusyMessage"
                                   Text="Creating records..."
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource OverlayText}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Click="BtnCancel_Click"
                    ToolTip="Close without creating any records."/>
            <Button x:Name="btnCreate"
                    Content="Create Selected"
                    Width="160"
                    Height="35"
                    Background="{DynamicResource AccentColor}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource AccentColor}"
                    BorderThickness="1"
                    Click="BtnCreate_Click"
                    ToolTip="Create the checked rows as new Activity + Snapshot stubs."/>
        </StackPanel>
    </Grid>
</Window>
