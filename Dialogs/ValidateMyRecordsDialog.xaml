<Window x:Class="VANTAGE.Dialogs.ValidateMyRecordsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        Title="Validate My Records"
        Height="600"
        Width="1250"
        MinHeight="400"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundColor}"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Validate My Records"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Foreground="{DynamicResource ForegroundColor}"/>
            <TextBlock Text="Scans your assigned activities for missing required metadata and invalid date/percent combinations. Any offenders found are automatically marked as unsaved so they appear in the ProgressView dirty highlight for follow-up edits."
                       Foreground="{DynamicResource ForegroundColor}"
                       Opacity="0.7"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Results grid -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlBorder}"
                BorderThickness="1"
                Background="{DynamicResource ControlBackground}"
                CornerRadius="4">
            <Grid>
                <syncfusion:SfDataGrid x:Name="sfIssues"
                                       AutoGenerateColumns="False"
                                       AllowEditing="False"
                                       AllowFiltering="True"
                                       AllowSorting="True"
                                       AllowResizingColumns="True"
                                       ColumnSizer="Auto"
                                       SelectionMode="Extended"
                                       ShowRowHeader="False"
                                       GridLinesVisibility="Horizontal"
                                       HeaderRowHeight="32"
                                       RowHeight="28"
                                       Background="Transparent"
                                       BorderThickness="0">
                    <syncfusion:SfDataGrid.Columns>
                        <syncfusion:GridTextColumn MappingName="ProjectID"
                                                   HeaderText="ProjectID"
                                                   Width="110"/>
                        <syncfusion:GridTextColumn MappingName="SchedActNO"
                                                   HeaderText="SchedActNO"
                                                   Width="140"/>
                        <syncfusion:GridTextColumn MappingName="Description"
                                                   HeaderText="Description"
                                                   Width="240"/>
                        <syncfusion:GridTextColumn MappingName="UniqueID"
                                                   HeaderText="UniqueID"
                                                   Width="160"/>
                        <syncfusion:GridTextColumn MappingName="Violation"
                                                   HeaderText="Violation"
                                                   Width="450"/>
                    </syncfusion:SfDataGrid.Columns>
                </syncfusion:SfDataGrid>

                <!-- Empty state -->
                <TextBlock x:Name="txtNoIssues"
                           Text="No issues found. All your records are valid."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ForegroundColor}"
                           Opacity="0.6"
                           Visibility="Collapsed"/>

                <!-- Loading overlay -->
                <Grid x:Name="pnlLoading"
                      Background="{DynamicResource ControlBackground}"
                      Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <syncfusion:SfBusyIndicator IsBusy="True"
                                                    AnimationType="DualRing"
                                                    ViewboxWidth="72"
                                                    ViewboxHeight="72"
                                                    Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock x:Name="txtBusyMessage"
                                   Text="Scanning your records..."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ForegroundColor}"
                                   HorizontalAlignment="Center"
                                   Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Summary -->
        <TextBlock x:Name="txtSummary"
                   Grid.Row="3"
                   Text=""
                   Foreground="{DynamicResource ForegroundColor}"
                   Opacity="0.7"
                   FontSize="12"
                   Margin="0,10,0,0"/>

        <!-- Buttons -->
        <Grid Grid.Row="5">
            <Button x:Name="btnExport"
                    Content="Export Report"
                    Width="140"
                    Height="35"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource ControlBackground}"
                    Foreground="{DynamicResource ForegroundColor}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    IsEnabled="False"
                    ToolTip="Save the issue list to an Excel file for reference while you fix records"
                    Click="BtnExport_Click"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="btnClose"
                        Content="Close"
                        Width="100"
                        Height="35"
                        Margin="0,0,10,0"
                        Background="{DynamicResource ControlBackground}"
                        Foreground="{DynamicResource ForegroundColor}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        Click="BtnClose_Click"/>
                <Button x:Name="btnShowInProgress"
                        Content="Show in ProgressView"
                        Width="170"
                        Height="35"
                        Background="{DynamicResource AccentColor}"
                        Foreground="{DynamicResource ForegroundColor}"
                        BorderBrush="{DynamicResource AccentColor}"
                        BorderThickness="1"
                        IsEnabled="False"
                        ToolTip="Switch to ProgressView with a filter pre-applied to only these records (won't show other dirty rows)"
                        Click="BtnShowInProgress_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
